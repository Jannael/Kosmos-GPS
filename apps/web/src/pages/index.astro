---
import Layout from '@/layouts/layout.astro'
import { SignInButton } from '@/components/SignInButton'
import { SessionRedirect } from '@/components/SessionRedirect'
---

<Layout title="Kosmos GPS — Soluciones de rastreo GPS">
	<SessionRedirect client:load />

	<div class="flex min-h-dvh flex-col items-center justify-center px-4">
		<div class="flex flex-col items-center gap-10 text-center">
			<div class="rounded-xl bg-gray-800 px-6 py-3">
				<img src="/kosmos-full-logo.png" alt="Kosmos GPS" class="h-12" />
			</div>

			<div class="flex flex-col items-center gap-4">
				<h1 class="text-text text-4xl font-bold tracking-tight sm:text-5xl">Soluciones de rastreo GPS</h1>
				<p class="text-text/60 max-w-md text-lg">Prueba técnica Kosmos GPS — este es un simple CRUD para gestionar inventario.</p>
			</div>

			<div class="flex flex-col items-center gap-4">
				<SignInButton client:load />

				<a
					href={`${import.meta.env.PUBLIC_API_BASE_URL}/openapi`}
					target="_blank"
					rel="noopener noreferrer"
					class="text-text/50 hover:text-text/80 text-sm underline underline-offset-2 transition-colors"
				>
					Ver API Docs
				</a>
			</div>

			<p class="text-text/40 text-sm">Inicia sesión con tu cuenta de GitHub para continuar</p>
		</div>
	</div>
</Layout>
